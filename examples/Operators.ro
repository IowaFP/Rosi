ex_adjacent_pre_post1 = (!!! (% ((!!! True) $$)))
ex_adjacent_pre_post2 = ! ! (% ((%%% 1) $$))
ex_adjacent_pre_post3 = ! % %%% 0 $$
ex_adjacent_pre_post4 = (!! ! %% True $$$)


swap = \f. (\a b. f b a)
(<->*) = swap
(*<->) = swap

prefix 11 <->*
postfix 11 *<->

(!*) = not
prefix 11 !*

ex_adjacent_exprs1 = f <->* (^) "a" "b" -- "ba"
ex_adjacent_exprs2 = (^) *<-> "a" "b" -- "ba"
ex_adjacent_exprs3 = and *<-> !* True False


-- exponent
(**) : Nat -> Nat -> Nat
(**) = fix (\exp x. 
    ('Zero: m -> 1
    |'Succ: m -> x * (exp x m))
  )

infixl 9 **

(&) : Nat -> Nat
(&) = mult 3

prefix 1 &

