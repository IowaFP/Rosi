-- check that we can override imported definition locally
(<>) : Nat -> Nat
(<>) n = 0
prefix 1 <>
z = <> 5


-- infixr 1 $++$

res = f ('hello := f "hello") $++$ f (f 'world := "world")

hello_world = "hello" :: "world" :: nil


ex_1 = (6 + (5 - 4) - 1) // 6
ex_2 = 7 // 7 + 6 // 6
ex_3 = 6 + 4 - 1 - 4 + 1 - 3
ex_4 = (4 + 4) // 2
ex_5 = 7 * 0 + 5 * 1
ex_6 = 20 - 7 * 2
ex_7 = 9 // 2 + 3
ex_8 = 6 + 5 - (4 - 1)
ex_9 = 6 + 6 // 2
ex_10 =  (*) 2 (3 + 2)
