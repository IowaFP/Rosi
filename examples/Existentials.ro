import Ro.Base, Data.Tuple, Data.Nat

-- Comparer over existentially hidden key type, as required for orderBy
type Comparer : * -> *
type Comparer = \t. exists v. (t -> v, Compare v)

compareField : {l := t} < z => #l -> Compare t -> Comparer (Pi z)
compareField l f = (.l, f)

compare : Comparer t -> Compare t
compare p x y = p.'2 (p.'1 x) (p.'1 y)

compared  : Cmp
compared  = compare (.'1, compN) (1, 2) (2, 1)

compared' : Cmp
compared' = compare (.'2, compN) (1, 2) (2, 1)

comparedHO  : Cmp
comparedHO  = compare (compareField '1 compN) (1, 2) (2, 1)

comparedHO' : Cmp
comparedHO' = compare (compareField '2 compN) (1, 2) (2, 1)

-- Just playing with syntax

type Bogus : * -> *
type Bogus = \t. exists u v. Pi {'1 := t -> u, '2 := t -> v, '3 := u -> v -> Bool}

bogoid : Bogus t -> t -> Bool
bogoid @t (@!u p : Bogus t) x = p.'3 (p.'1 x) (p.'2 x)

bogoid2 @t (p : Bogus t) x = p.'3 (p.'1 x) (p.'2 x)

-- Can make implicit existential explicit...

compareField' : forall z. {l := t} < z => #l -> Compare t -> Comparer (Pi z)
compareField' @z l f = pack #(\v. (Pi z -> v, Compare v)) (.l, f)

-- Let's use some constraints

type Subrecord : R[*] -> *
type Subrecord z = exists y. y < z => Pi y

updateS : Subrecord z -> Pi z -> Pi z
updateS r s = upd r s

updated = updateS ('1 := 2) ('1 := 1, '2 := 2)

-- Typing fails, as it should: '3 is not contained in {'1 := Nat, '2 := Nat}
