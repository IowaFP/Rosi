import Ro.Base, Data.List, Data.Nat

($++$) a b = a ++ b

f = id

(+) = add

(-) = monus

(*) = mult

(//) = div

-- Test that we support the Idris 2 operator set except for '.', '#', and '@'
(+-*\/=?|&><!$%^~) = id

-- we can declare fixity for operators defined in the same file
infixl 5 +

infixl 7 //

infixl 7 *

infixl 5 -

