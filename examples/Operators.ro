prefix 7 !
prefix 8 !!
prefix 9 !!!
postfix 7 $
postfix 8 $$
postfix 9 $$$
prefix 7 %
prefix 8 %%
prefix 9 %%%

(!) = Ro.Base.not
(!!) = not
(!!!) = not
(/\) = Ro.Base.and
(\/) = Ro.Base.or
(&&) = Ro.Base.and
(||) = Ro.Base.or

(==>) p q = (! p) \/ q

infixl 6 /\
infixl 9 || -- or with highest precedence
infixl 6 \/
infixl 9 && -- and with highest precedence
infixr 4 ==>

postfix 1 << -- loosely binding postfix negation
postfix 9 <<< -- tightly binding postfix negation

(<<) = not
(<<<) = not


($) : Bool -> Nat
($) = 'True: u -> 1
    | 'False: u -> 0
($$) = ($)
($$$) = ($$)

natToBool : Nat -> Bool
natToBool = 'Succ: u -> True 
          | 'Zero: u -> False

(%) = natToBool
(%%) = natToBool
(%%%) = natToBool

ex_T1 = ! False
ex_T2 = True \/ False <<< -- if <<< binds loosely, False. if <<< binds tightly, True
ex_T3 = True ==> True <<< <<
ex_T4 = True ==> True << <<<
ex_T5 = True /\ False \/ True
ex_T6 = ! False \/ ! True
ex_T7 = ! ! False || True
ex_T8 = True ==> False ==> True ==> False
ex_T9 = True ==> False <<
ex_T10 = True ==> False <<<

ex_F1 = ! True
ex_F2 = ! False <<
ex_F3 = True ==> False << <<<
ex_F4 = True \/ False << -- if << binds loosely, False. if << binds tightly, True
ex_F5 = False \/ True /\ False
ex_F6 = ! True || ! False
ex_F7 = True ==> True \/ False ==> False
ex_F8 = ! False || True
ex_F9 = True ==> ! False ==> ! True || True
ex_F10 = ! False ==> ! True || ! False

