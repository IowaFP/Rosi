prefix 7 !
prefix 8 !!
prefix 9 !!!
postfix 7 $
postfix 8 $$
postfix 9 $$$
prefix 7 %
prefix 8 %%
prefix 9 %%%

(!) = Ro.Base.not
(!!) = not
(!!!) = not
(/\) = Ro.Base.and
(\/) = Ro.Base.or
(&&) = Ro.Base.and
(||) = Ro.Base.or

(==>) p q = (! p) \/ q

infixl 6 /\
infixl 9 || -- or with highest precedence
infixl 6 \/
infixl 9 && -- and with highest precedence
infixr 4 ==>

postfix 1 << -- loosely binding postfix negation
postfix 9 <<< -- tightly binding postfix negation

(<<) = not
(<<<) = not


($) : Bool -> Nat
($) = 'True: u -> 1
    | 'False: u -> 0
($$) = ($)
($$$) = ($$)

natToBool : Nat -> Bool
natToBool = 'Succ: u -> True 
          | 'Zero: u -> False

(%) = natToBool
(%%) = natToBool
(%%%) = natToBool

ex_T1 = ! False
ex_T2 = True \/ False <<< -- if <<< binds loosely, False. if <<< binds tightly, True
ex_T3 = True ==> True <<< <<
ex_T4 = True ==> True << <<<
ex_T5 = True /\ False \/ True
ex_T6 = ! False \/ ! True
ex_T7 = ! ! False || True
ex_T8 = True ==> False ==> True ==> False
ex_T9 = True ==> False <<
ex_T10 = True ==> False <<<

ex_F1 = ! True
ex_F2 = ! False <<
ex_F3 = True ==> False << <<<
ex_F4 = True \/ False << -- if << binds loosely, False. if << binds tightly, True
ex_F5 = False \/ True /\ False
ex_F6 = ! True || ! False
ex_F7 = True ==> True \/ False ==> False
ex_F8 = ! False || True
ex_F9 = True ==> ! False ==> ! True || True
ex_F10 = ! False ==> ! True || ! False

-- these (probably) won't typecheck if precedence isn't resolved correctly
ex_adjacent_pre_post1 = (!!! (% ((!!! True) $$)))
ex_adjacent_pre_post2 = ! ! (% ((%%% 1) $$))
ex_adjacent_pre_post3 = ! % %%% 0 $$
ex_adjacent_pre_post4 = (!! ! %% True $$$)


swap = \f. (\a b. f b a)
(<->*) = swap
(*<->) = swap

prefix 11 <->*
postfix 11 *<->

(!*) = not
prefix 11 !*

ex_adjacent_exprs1 = f <->* (^) "a" "b" -- "ba"
ex_adjacent_exprs2 = (^) *<-> "a" "b" -- "ba"
ex_adjacent_exprs3 = and *<-> !* True False


-- exponent
(**) : Nat -> Nat -> Nat
(**) = fix (\exp x. 
    ('Zero: m -> 1
    |'Succ: m -> x * (exp x m))
  )

infixl 9 **

(&) : Nat -> Nat
(&) = mult 3

prefix 1 &

exp_1 = 2**0
exp_2 = 2**1
exp_4 = 2**2
exp_8 = 2**3 -- 8
exp_24 = & 2**3

(+++) : Nat -> Nat
(+++) = succ

-- infix 9 +++
prefix 11 +++

-- If I call the recursive parameter fold,
-- It gets parsed using the fold operator inside the type arguments
-- Operators.fold' = \p fix @((Fold a#121@15 => (#a#122@14 -> (forall l : L. forall u : %e#88. {l@1 := u@0} < a#121@17 => #l@1 -> a#122@16 u@0 -> a#123@15) -> (a#123@13 -> a#123@13 -> a#123@13) -> a#123@13 -> Pi a#121@15 -> a#123@13) -> a#124@12) -> a#125@11 -> Sigma {'Cons := Pi a#126@10, 'Nil := a#127@9} -> a#125@11) (\ (fold : (Fold a#121@7 => (#a#122@6 -> (forall l : L. forall u : %e#88. {l@1 := u@0} < a#121@9 => #l@1 -> a#122@8 u@0 -> a#123@7) -> (a#123@5 -> a#123@5 -> a#123@5) -> a#123@5 -> Pi a#121@7 -> a#123@5) -> a#124@4) -> a#125@3 -> Sigma {'Cons := Pi a#126@2, 'Nil := a#127@1} -> a#125@3) (+++ : Fold a#121@7 => (#a#122@6 -> (forall l : L. forall u : %e#88. {l@1 := u@0} < a#121@9 => #l@1 -> a#122@8 u@0 -> a#123@7) -> (a#123@5 -> a#123@5 -> a#123@5) -> a#123@5 -> Pi a#121@7 -> a#123@5) -> a#124@4) (z : a#125@3) . Ro.Base.case @('Nil) @(a#127@9) @(a#125@11) #'Nil (\ (u : a#127@1) . z) | Ro.Base.case @('Cons) @(Pi a#126@10) @(a#125@11) #'Cons (\ (p : Pi a#126@2) . Ro.Base.sel @('1) @([^8%i#68] (a#124@12 -> [^8%i#66] ((Fold a#121@15 => (#a#122@14 -> (forall l : L. forall u : %e#88. {l@1 := u@0} < a#121@17 => #l@1 -> a#122@16 u@0 -> a#123@15) -> (a#123@13 -> a#123@13 -> a#123@13) -> a#123@13 -> Pi a#121@15 -> a#123@13) -> a#124@12) -> [^8%i#64] (a#128@8 -> [^8%i#62] (a#125@11))))) @(a#126@10)  p #'1 [i#68] (+++ (fold @(a#122@14) @(a#121@15) @(a#123@13))) [i#66] +++ [i#64] (Ro.Base.sel @('2) @([^8%i#94] (a#128@8)) @(a#126@10)  p #'2 [i#94]) [i#62]))
fold' : (Nat -> Nat -> Nat) -> Nat -> List Nat -> Nat
fold' = (fix (\fold' (+++) z.
  'Nil: u -> z
  |'Cons: p -> p.'1 +++ fold' (+++) z p.'2))
