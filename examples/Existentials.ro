-- compared' : Cmp
-- compared' = compare (compareField '1 compN) ('1 := 1, '2 := 2) ('1 := 2, '2 := 1)

-- Just playing with syntax

type Bogus : * -> *
type Bogus = \t. exists u. exists v. Pi {'1 := t -> u, '2 := t -> v, '3 := u -> v -> Bool}

bogoid : Bogus t -> t -> Bool
bogoid @t (@!u p : Bogus t) x = p.'3 (p.'1 x) (p.'2 x)

bogoid2 @t (p : Bogus t) x = p.'3 (p.'1 x) (p.'2 x)
